# Build artifacts. The bundled MCP server lives under plugin/mcp/dist/
# (so it ships with the plugin install). Ignore everything else under that
# directory tree to keep esbuild cache / sourcemaps out of the install.
plugin/mcp/dist/*
!plugin/mcp/dist/index.js

